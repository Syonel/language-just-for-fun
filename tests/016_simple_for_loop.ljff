for var i: int = 0; i < 5; i = i + 1 {
    var j: int = i*i;
    print(j);
}

for var i: int = 0; i < 5 {
    print(i);
    i = i + 1;
}

var i: int = 0;
for i < 5 {
    print(i);
    i = i + 1;
}

i = 0;
for {
    if i >= 5 {
        break;
    }
    print(i);
    i = i + 1;
}

for var i: int = 0; i < 10; i = i + 1 {
    if i == 2 {
         continue;
    }
    if i == 5 {
        break;
    }
    print(i);
}

for var i: int = 0; i < 5; i = i + 1 {
    for var j: int = 0; j < 5; j = j + 1 {
        print(i*10+j);
    }
}